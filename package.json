{
  "name": "@adminforth/storage-adapter-s3-compatible",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc"
  },
  "keywords": [],
  "author": "DevForth (https://devforth.io)",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "adminforth": "^3.2.2",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devforth/adminforth-storage-adapter-s3-compatible.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/s3-request-presigner": "^3.800.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "adminforth": "^3.2.1"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      [
        "@semantic-release/github",
        {
          "successComment": false,
          "failComment": false,
          "releasedLabels": false
        }
      ],
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/storage-adapter-s3-compatible",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ],
    "branches": [
      "main",
      { 
        "name": "next",
        "prerelease": true
      }
    ]
  }
}
